{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 3,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 62,
      "regions": [
        "iad1"
      ]
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index" },
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/api/index" }
  ],
  "trailingSlash": false
}

